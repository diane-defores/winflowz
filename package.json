{
  "name": "winflowz",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "clean": "rimraf dist .vercel/output node_modules/.vite",
    "typecheck": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro check --tsconfig ./tsconfig.json",
    "build:check": "astro check --tsconfig ./tsconfig.json",
    "build:analyze": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build --analyze",
    "build:astro": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build",
    "build:debug": "set NODE_OPTIONS=\"--inspect --inspect-brk\" && astro build",
    "build": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build --force",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^8.3.4",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/starlight": "^0.28.6",
    "@astrojs/starlight-tailwind": "^2.0.3",
    "@astrojs/tailwind": "^5.1.4",
    "@astrojs/vercel": "^7.8.2",
    "@heroicons/react": "^2.2.0",
    "@preline/accordion": "^2.6.0",
    "@preline/collapse": "^2.6.0",
    "@preline/dropdown": "^2.6.0",
    "@preline/overlay": "^2.6.0",
    "@preline/tabs": "^2.6.0",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/supabase-js": "^2.47.12",
    "@vercel/nft": "^0.27.10",
    "astro": "^4.16.18",
    "astro-compressor": "^0.4.1",
    "astro-icon": "^1.1.5",
    "astro-vtbot": "^1.10.7",
    "clipboard": "^2.0.11",
    "globby": "^14.0.2",
    "gsap": "^3.12.5",
    "html-minifier-terser": "^7.2.0",
    "lenis": "^1.1.19",
    "preline": "^2.7.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.5",
    "sharp-ico": "^0.1.5",
    "stripe": "^17.5.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "supabase": "^2.2.1",
    "typescript": "^5.7.3"
  }
}
