---
import MainLayout from "../../layouts/MainLayout.astro";

interface Feature {
  id: string;
  title: string;
  description: string;
  status: "in-development" | "planned" | "considering" | "completed";
  votes: number;
}

const features: Feature[] = [
  {
    id: "1",
    title: "Système d'Authentification",
    description: "Implémenter une authentification et une autorisation sécurisées",
    status: "in-development",
    votes: 42
  },
  {
    id: "2",
    title: "Mode Sombre",
    description: "Ajouter le support du mode sombre dans toute l'application",
    status: "completed",
    votes: 38
  }
];

function getStatusIcon(status: Feature["status"]) {
  switch (status) {
    case "in-development":
      return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
      </svg>`;
    case "planned":
      return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
      </svg>`;
    case "considering":
      return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
      </svg>`;
    case "completed":
      return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>`;
  }
}

function getStatusLabel(status: Feature["status"]) {
  switch (status) {
    case "in-development":
      return "En développement";
    case "planned":
      return "Planifié";
    case "considering":
      return "À l'étude";
    case "completed":
      return "Terminé";
    default:
      return status;
  }
}
---

<MainLayout title="Feuille de Route">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0">
      <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Feuille de Route</h1>
      <p class="mt-2 text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        Votez pour les fonctionnalités que vous souhaitez voir implémentées
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-6 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      {features.map((feature) => (
        <div class="flex flex-col rounded-lg border border-neutral-200 p-6 dark:border-neutral-800">
          <div class="flex items-center gap-x-3">
            <div class="text-neutral-600 dark:text-neutral-400" set:html={getStatusIcon(feature.status)} />
            <span class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
              {getStatusLabel(feature.status)}
            </span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-neutral-900 dark:text-white">{feature.title}</h3>
          <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{feature.description}</p>
          <div class="mt-4">
            <button class="group flex items-center gap-2 rounded-lg border border-neutral-200 px-3 py-1.5 text-sm font-medium text-neutral-700 transition-colors hover:border-neutral-300 hover:bg-neutral-50 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-neutral-700 dark:hover:bg-neutral-800/50">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 text-neutral-400 transition-colors group-hover:text-neutral-500 dark:text-neutral-500 dark:group-hover:text-neutral-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
              </svg>
              <span>{feature.votes}</span>
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout> 