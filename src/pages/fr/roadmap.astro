---
import MainLayout from "../../layouts/MainLayout.astro";
import FeatureCard from "../../components/roadmap/FeatureCard.astro";
import ProjectNav from "../../components/roadmap/ProjectNav.astro";
import { projects } from "../../types/roadmap";

const allFeatures = projects.flatMap(project => project.features);
---

<MainLayout title="Feuille de Route">
  <div class="min-h-screen bg-white dark:bg-neutral-900">
    <ProjectNav />
    
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Feuille de Route</h1>
        <p class="mt-2 text-lg leading-8 text-neutral-600 dark:text-neutral-400">
          Découvrez nos projets et votez pour les fonctionnalités que vous souhaitez voir implémentées
        </p>
      </div>

      <div class="mt-16 space-y-20">
        {projects.map(project => (
          <section>
            <div class="mb-8">
              <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
                <a href={`/fr/roadmap/${project.id}`} class="hover:text-orange-500 dark:hover:text-orange-400">
                  {project.name}
                </a>
              </h2>
              <p class="mt-2 text-lg text-neutral-600 dark:text-neutral-400">
                {project.description}
              </p>
            </div>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {project.features.map(feature => (
                <FeatureCard feature={feature} />
              ))}
            </div>
          </section>
        ))}
      </div>

      <section class="mt-20">
        <h2 class="mb-8 text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">Toutes les fonctionnalités</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {allFeatures
            .sort((a, b) => b.votes - a.votes)
            .map(feature => (
              <FeatureCard feature={feature} showProjectName={true} />
            ))}
        </div>
      </section>
    </div>
  </div>
</MainLayout> 