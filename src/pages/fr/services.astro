---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";
import { getRelativeLocaleUrl } from 'astro:i18n';

// Import necessary images
import blueprints from "@images/blueprints-image.avif";
import personWorking from "@images/person-working.avif";
import beforeAfter from "@images/before-after.avif";
import constructionWorkers from "@images/construction-workers.avif";
import aerialView from "@images/aerial-view.avif";
import usingTools from "@images/using-tools.avif";
import progressBuilding from "@images/progress-building.avif";
import underConstruction from "@images/under-construction.avif";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Développement Sur Mesure",
    subTitle:
      "En tant que développeuse neurodivergente spécialisée dans les outils de productivité et passionnée d'UX/UI, je crée des solutions personnalisées qui améliorent votre flux de travail numérique. Des plugins Obsidian aux extensions Chrome, chaque projet est méticuleusement conçu pour répondre à vos besoins spécifiques tout en garantissant une performance et une expérience utilisateur optimales.",
    single: false,
    imgOne: blueprints,
    imgOneAlt: "Illustration du flux de développement",
    imgTwo: personWorking,
    imgTwoAlt: "Personne travaillant avec des outils numériques",
  },
  {
    isRightSection: false,
    title: "Formation en Productivité",
    subTitle:
      "Transformez votre flux de travail numérique avec des conseils d'expert. Je propose des sessions de formation personnalisées axées sur l'optimisation de la productivité, la maîtrise des outils et l'amélioration des processus. Que vous soyez débutant ou utilisateur avancé, mon approche s'adapte à votre style d'apprentissage et à vos objectifs.",
    img: beforeAfter,
    imgAlt: "Session de formation en productivité",
    btnExists: true,
    btnTitle: "En savoir plus",
    btnURL: "#",
  },
  {
    isRightSection: true,
    title: "Expertise WordPress",
    subTitle:
      "Maîtrisez WordPress avec une formation complète, des bases aux fonctionnalités avancées. Je fournis un accompagnement pratique pour la création, la personnalisation et l'optimisation de sites web. Apprenez à gérer efficacement votre contenu tout en appliquant les meilleures pratiques pour la performance et le SEO.",
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: "Illustration du développement WordPress",
    imgTwo: aerialView,
    imgTwoAlt: "Aperçu de la gestion de site web",
  },
  {
    isRightSection: false,
    title: "Implémentation Logicielle",
    subTitle:
      "Bénéficiez d'un support personnalisé pour l'implémentation et la maîtrise des outils logiciels essentiels. D'Obsidian aux applications de productivité, je vous aide à optimiser votre espace de travail numérique et à établir des flux de travail efficaces adaptés à vos besoins.",
    img: usingTools,
    imgAlt: "Démonstration d'implémentation logicielle",
  },
  {
    isRightSection: true,
    title: "Solutions & Intégration Sur Mesure",
    subTitle:
      "Besoin d'un outil spécifique ou d'une amélioration de votre flux de travail ? Je développe des solutions personnalisées qui s'intègrent parfaitement à vos systèmes existants. Des scripts d'automatisation aux plugins spécialisés, je crée des outils qui boostent votre productivité et optimisent vos processus de travail, toujours avec un accent particulier sur l'expérience utilisateur et le design d'interface.",
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: "Processus de développement personnalisé",
    imgTwo: underConstruction,
    imgTwoAlt: "Flux d'intégration",
    btnExists: true,
    btnTitle: "Explorer les Solutions",
    btnURL: "#",
  },
];
---

<MainLayout
  title="Services | WinFlowz"
  lang="fr"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://winflowz.com/fr/services",
    url: "https://winflowz.com/fr/services",
    name: "Services de Productivité Numérique & Formation | WinFlowz",
    description:
      "Services experts de développement et de formation pour l'amélioration de la productivité numérique. Plugins personnalisés, extensions et coaching personnalisé pour optimiser votre flux de travail.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://winflowz.com/fr",
      name: "WinFlowz",
      description:
        "Outils de productivité numérique et formation par une experte neurodivergente.",
    },
    inLanguage: "fr",
  }}
>
  <MainSection
    title="Optimisez Votre Productivité Numérique"
    subTitle="Transformez votre flux de travail avec du développement sur mesure et une formation experte. En tant que développeuse neurodivergente, passionnée d'UX/UI et spécialiste de la productivité, je propose des solutions et des conseils personnalisés pour vous aider à atteindre une efficacité maximale dans votre espace de travail numérique."
    btnExists={true}
    btnTitle="Planifier une consultation"
    btnURL={getRelativeLocaleUrl("fr", "#")}
  />
  {
    articles.map((article) => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  <FeaturesStats
    title="Impact & Résultats"
    subTitle="Mon engagement envers l'amélioration de la productivité numérique se reflète dans le succès de mes clients et l'efficacité de mes solutions."
    mainStatTitle="96%"
    mainStatSubTitle="des clients constatent des améliorations significatives de leur productivité après implémentation"
    stats={[
      {
        stat: "50+",
        description: "solutions personnalisées livrées",
      },
      {
        stat: "200+",
        description: "astuces et techniques de productivité",
      },
      {
        stat: "85%",
        description: "de temps gagné sur les tâches répétitives",
      },
    ]}
  />
</MainLayout>
