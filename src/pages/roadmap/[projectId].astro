---
import MainLayout from "../../layouts/MainLayout.astro";
import ProjectNav from "../../components/roadmap/ProjectNav.astro";
import KanbanBoard from "../../components/roadmap/KanbanBoard.astro";
import { projects } from "../../types/roadmap";

const { projectId } = Astro.params;
const project = projects.find(p => p.id === projectId);

if (!project) {
  return Astro.redirect("/404");
}
---

<MainLayout title={`${project.name} - Roadmap`}>
  <ProjectNav currentProjectId={projectId} />
  
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0">
      <div class="flex items-center gap-x-3">
        <a href="/roadmap" class="text-sm font-medium text-neutral-500 hover:text-orange-500 dark:text-neutral-400 dark:hover:text-orange-400">
          ← Retour à la roadmap
        </a>
      </div>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">{project.name}</h1>
      <p class="mt-2 text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        {project.description}
      </p>
    </div>

    <KanbanBoard features={project.features} />
  </div>
</MainLayout> 