---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCurrentUser } from "../../lib/supabase";
import Header from "../../components/ui/dashboard/Header.astro";
import Sidebar from "../../components/ui/dashboard/Sidebar.astro";
export const prerender = false;

const user = await getCurrentUser();
---

<MainLayout title="Tâches - Dashboard">
  <div class="flex h-screen bg-neutral-50 dark:bg-neutral-900">
    <aside class="w-64 flex-shrink-0">
      <Sidebar currentPath={Astro.url.pathname} />
    </aside>

    <div class="flex-1 flex flex-col overflow-hidden">
      <Header userEmail={user?.email || ''} />

      <main class="flex-1 overflow-y-auto">
        <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          <div class="md:flex md:items-center md:justify-between">
            <div class="min-w-0 flex-1">
              <h2 class="text-2xl font-bold leading-7 text-neutral-900 dark:text-neutral-100 sm:truncate sm:text-3xl sm:tracking-tight">
                Tâches
              </h2>
            </div>
            <div class="mt-4 flex md:ml-4 md:mt-0">
              <button
                type="button"
                class="inline-flex items-center rounded-md bg-neutral-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-neutral-700 dark:bg-neutral-700 dark:hover:bg-neutral-600"
              >
                <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Nouvelle tâche
              </button>
            </div>
          </div>

          {/* Filtres */}
          <div class="mt-4">
            <select class="rounded-md border-neutral-300 py-1.5 pl-3 pr-10 text-sm dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200">
              <option>Toutes les tâches</option>
              <option>En cours</option>
              <option>Terminées</option>
              <option>En attente</option>
            </select>
          </div>

          {/* Liste des tâches */}
          <div class="mt-4 overflow-hidden rounded-lg bg-white shadow dark:bg-neutral-800">
            <div class="p-6">
              <p class="text-center text-neutral-500 dark:text-neutral-400">
                Aucune tâche pour le moment
              </p>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</MainLayout> 