---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCurrentUser } from "../../lib/supabase";
import Header from "../../components/ui/dashboard/Header.astro";
import Sidebar from "../../components/ui/dashboard/Sidebar.astro";

const user = await getCurrentUser();
---

<MainLayout title="Paramètres - Dashboard">
  <div class="flex h-screen bg-neutral-50 dark:bg-neutral-900">
    <aside class="w-64 flex-shrink-0">
      <Sidebar currentPath={Astro.url.pathname} />
    </aside>

    <div class="flex-1 flex flex-col overflow-hidden">
      <Header userEmail={user?.email || ''} />

      <main class="flex-1 overflow-y-auto">
        <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          <div class="md:flex md:items-center md:justify-between">
            <div class="min-w-0 flex-1">
              <h2 class="text-2xl font-bold leading-7 text-neutral-900 dark:text-neutral-100 sm:truncate sm:text-3xl sm:tracking-tight">
                Paramètres
              </h2>
            </div>
          </div>

          <div class="mt-6 space-y-8 divide-y divide-neutral-200 dark:divide-neutral-700">
            {/* Section Profil */}
            <div class="space-y-6 pt-8 sm:space-y-5">
              <div>
                <h3 class="text-lg font-medium leading-6 text-neutral-900 dark:text-neutral-100">
                  Profil
                </h3>
                <p class="mt-1 max-w-2xl text-sm text-neutral-500 dark:text-neutral-400">
                  Gérez vos informations personnelles
                </p>
              </div>

              <div class="space-y-6 sm:space-y-5">
                <div class="sm:grid sm:grid-cols-3 sm:items-start sm:gap-4">
                  <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 sm:mt-px sm:pt-2">
                    Photo de profil
                  </label>
                  <div class="mt-1 sm:col-span-2 sm:mt-0">
                    <div class="flex items-center">
                      <img
                        class="h-12 w-12 rounded-full"
                        src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix"
                        alt="Avatar"
                      />
                      <button
                        type="button"
                        class="ml-5 rounded-md border border-neutral-300 bg-white py-2 px-3 text-sm font-medium text-neutral-700 hover:bg-neutral-50 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-700"
                      >
                        Changer
                      </button>
                    </div>
                  </div>
                </div>

                <div class="sm:grid sm:grid-cols-3 sm:items-start sm:gap-4">
                  <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 sm:mt-px sm:pt-2">
                    Email
                  </label>
                  <div class="mt-1 sm:col-span-2 sm:mt-0">
                    <input
                      type="email"
                      value={user?.email || ''}
                      disabled
                      class="block w-full max-w-lg rounded-md border-neutral-300 shadow-sm disabled:cursor-not-allowed disabled:bg-neutral-50 disabled:text-neutral-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-300 sm:max-w-xs"
                    />
                  </div>
                </div>
              </div>
            </div>

            {/* Section Notifications */}
            <div class="space-y-6 pt-8 sm:space-y-5">
              <div>
                <h3 class="text-lg font-medium leading-6 text-neutral-900 dark:text-neutral-100">
                  Notifications
                </h3>
                <p class="mt-1 max-w-2xl text-sm text-neutral-500 dark:text-neutral-400">
                  Configurez vos préférences de notification
                </p>
              </div>

              <div class="space-y-6 sm:space-y-5">
                <div class="sm:grid sm:grid-cols-3 sm:items-start sm:gap-4">
                  <div class="text-sm font-medium text-neutral-700 dark:text-neutral-300 sm:mt-px sm:pt-2">
                    Email
                  </div>
                  <div class="mt-1 sm:col-span-2 sm:mt-0">
                    <div class="space-y-4">
                      <div class="flex items-center">
                        <input
                          type="checkbox"
                          class="h-4 w-4 rounded border-neutral-300 text-neutral-600 focus:ring-neutral-500 dark:border-neutral-600 dark:bg-neutral-800"
                        />
                        <label class="ml-3 text-sm text-neutral-700 dark:text-neutral-300">
                          Nouvelles tâches
                        </label>
                      </div>
                      <div class="flex items-center">
                        <input
                          type="checkbox"
                          class="h-4 w-4 rounded border-neutral-300 text-neutral-600 focus:ring-neutral-500 dark:border-neutral-600 dark:bg-neutral-800"
                        />
                        <label class="ml-3 text-sm text-neutral-700 dark:text-neutral-300">
                          Mises à jour des projets
                        </label>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Section Sécurité */}
            <div class="space-y-6 pt-8 sm:space-y-5">
              <div>
                <h3 class="text-lg font-medium leading-6 text-neutral-900 dark:text-neutral-100">
                  Sécurité
                </h3>
                <p class="mt-1 max-w-2xl text-sm text-neutral-500 dark:text-neutral-400">
                  Gérez vos paramètres de sécurité
                </p>
              </div>

              <div class="space-y-6 sm:space-y-5">
                <div class="sm:grid sm:grid-cols-3 sm:items-start sm:gap-4">
                  <div class="text-sm font-medium text-neutral-700 dark:text-neutral-300 sm:mt-px sm:pt-2">
                    Mot de passe
                  </div>
                  <div class="mt-1 sm:col-span-2 sm:mt-0">
                    <button
                      type="button"
                      class="rounded-md bg-neutral-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-neutral-700 dark:bg-neutral-700 dark:hover:bg-neutral-600"
                    >
                      Changer le mot de passe
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</MainLayout> 