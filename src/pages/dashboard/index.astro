---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCurrentUser } from "../../lib/supabase";
import Header from "../../components/ui/dashboard/Header.astro";
import Sidebar from "../../components/ui/dashboard/Sidebar.astro";
import Stats from "../../components/ui/dashboard/Stats.astro";

// Récupérer l'utilisateur actuel
const user = await getCurrentUser();

// Vérifier si l'utilisateur vient de confirmer son email
const isNewlyConfirmed = Astro.url.searchParams.get('newly_confirmed') === 'true';
---

<MainLayout title="Dashboard">
  <div class="flex h-screen bg-neutral-50 dark:bg-neutral-900">
    {/* Sidebar */}
    <aside class="w-64 flex-shrink-0">
      <Sidebar currentPath={Astro.url.pathname} />
    </aside>

    {/* Main Content */}
    <div class="flex-1 flex flex-col overflow-hidden">
      <Header userEmail={user?.email || ''} />

      <main class="flex-1 overflow-y-auto">
        <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          {/* Message de bienvenue pour les nouveaux utilisateurs confirmés */}
          {isNewlyConfirmed && (
            <div class="mb-8 rounded-lg bg-green-50 p-4 dark:bg-green-900/50">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-green-800 dark:text-green-200">
                    Inscription réussie !
                  </h3>
                  <div class="mt-2 text-sm text-green-700 dark:text-green-300">
                    <p>
                      Merci d'avoir confirmé votre email. Votre compte est maintenant actif.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* En-tête de la section */}
          <div class="md:flex md:items-center md:justify-between">
            <div class="min-w-0 flex-1">
              <h2 class="text-2xl font-bold leading-7 text-neutral-900 dark:text-neutral-100 sm:truncate sm:text-3xl sm:tracking-tight">
                Vue d'ensemble
              </h2>
            </div>
          </div>

          {/* Statistiques */}
          <div class="mt-8">
            <Stats />
          </div>

          {/* Section des produits achetés */}
          <div class="mt-8">
            <h3 class="text-lg font-medium leading-6 text-neutral-900 dark:text-neutral-100">
              Vos produits achetés
            </h3>
            <div class="mt-4 overflow-hidden rounded-lg bg-white shadow dark:bg-neutral-800">
              <div class="p-6">
                <p class="text-center text-neutral-500 dark:text-neutral-400">
                  Vous n'avez pas encore acheté de produits
                </p>
              </div>
            </div>
          </div>

          {/* Section des produits non possédés */}
          <div class="mt-8">
            <h3 class="text-lg font-medium leading-6 text-neutral-900 dark:text-neutral-100">
              Les produits que vous ne possédez pas encore
            </h3>
            <div class="mt-4 overflow-hidden rounded-lg bg-white shadow dark:bg-neutral-800">
              <div class="p-6">
                <p class="text-center text-neutral-500 dark:text-neutral-400">
                  Découvrez notre catalogue de produits
                </p>
                <div class="mt-4 text-center">
                  <a
                    href="/fr/produits"
                    class="inline-flex items-center rounded-md bg-neutral-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-neutral-700 dark:bg-neutral-700 dark:hover:bg-neutral-600"
                  >
                    Voir les produits
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</MainLayout> 