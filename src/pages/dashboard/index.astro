---
import MainLayout from "../../layouts/MainLayout.astro";w
import { getCurrentUser } from "../../lib/supabase";

// Récupérer l'utilisateur actuel
const user = await getCurrentUser();

// Vérifier si l'utilisateur vient de confirmer son email
const isNewlyConfirmed = Astro.url.searchParams.get('newly_confirmed') === 'true';
---

<MainLayout title="Dashboard">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    {/* Message de bienvenue pour les nouveaux utilisateurs confirmés */}
    {isNewlyConfirmed && (
      <div class="mb-8 rounded-lg bg-green-50 p-4 dark:bg-green-900/50">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-green-800 dark:text-green-200">
              Inscription réussie !
            </h3>
            <div class="mt-2 text-sm text-green-700 dark:text-green-300">
              <p>
                Merci d'avoir confirmé votre email. Votre compte est maintenant actif.
              </p>
            </div>
          </div>
        </div>
      </div>
    )}

    {/* En-tête du dashboard */}
    <div class="md:flex md:items-center md:justify-between">
      <div class="min-w-0 flex-1">
        <h2 class="text-2xl font-bold leading-7 text-neutral-900 dark:text-neutral-100 sm:truncate sm:text-3xl sm:tracking-tight">
          Bienvenue, {user?.email}
        </h2>
      </div>
    </div>

    {/* Contenu principal du dashboard */}
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {/* Carte des statistiques */}
      <div class="overflow-hidden rounded-lg bg-neutral-50 shadow dark:bg-neutral-800">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="truncate text-sm font-medium text-neutral-500 dark:text-neutral-400">
                  Statut du compte
                </dt>
                <dd>
                  <div class="text-lg font-medium text-neutral-900 dark:text-neutral-200">
                    Actif
                  </div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout> 