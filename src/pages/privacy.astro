---
import MainLayout from "@/layouts/MainLayout.astro";

const pageTitle = "Privacy Policy | WinFlowz";
---

<MainLayout
  title={pageTitle}
  lang="en"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://winflowz.com/privacy",
    "url": "https://winflowz.com/privacy",
    "name": "Privacy Policy | WinFlowz",
    "description": "Privacy policy and personal data protection for WinFlowz digital productivity tools and services.",
    "inLanguage": "en"
  }}
>
  <div class="max-w-4xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold mb-8 text-neutral-900 dark:text-white">Privacy Policy</h1>

    <p class="text-sm mb-4 text-neutral-500 dark:text-neutral-400">Last updated: December 15, 2024</p>

    <div class="space-y-6 text-neutral-600 dark:text-neutral-400">
      <p>
        At WinFlowz, we take your privacy seriously. This Privacy Policy explains how we collect, use, and protect your personal information when you use our products and services.
      </p>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">1. Information Collection</h2>
      <p>We collect minimal personal information, limited to:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Email address (for account management)</li>
        <li>Payment information (processed securely by third-party providers)</li>
        <li>Usage analytics (anonymized)</li>
      </ul>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">2. Data Usage</h2>
      <p>Your information is used for:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Account management</li>
        <li>Product delivery</li>
        <li>Customer support</li>
        <li>Service improvements</li>
      </ul>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">3. Data Protection</h2>
      <p>We implement security measures including:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Encryption of sensitive data</li>
        <li>Secure payment processing</li>
        <li>Regular security audits</li>
        <li>Access controls</li>
      </ul>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">4. Third-Party Services</h2>
      <p>We use trusted third-party services for:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Payment processing</li>
        <li>Analytics</li>
        <li>Email communication</li>
        <li>Hosting</li>
      </ul>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">5. Your Rights</h2>
      <p>You have the right to:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Access your data</li>
        <li>Request data deletion</li>
        <li>Opt-out of communications</li>
        <li>Request data corrections</li>
      </ul>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">6. Cookies</h2>
      <p>We use essential cookies for:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Session management</li>
        <li>Authentication</li>
        <li>User preferences</li>
      </ul>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">7. Updates</h2>
      <p>
        This policy may be updated periodically. Users will be notified of significant changes.
      </p>

      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">8. Contact</h2>
      <p>
        For privacy concerns, contact: privacy@winflowz.com
      </p>
    </div>
  </div>
</MainLayout>
