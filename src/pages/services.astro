---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";

// Import necessary images
import blueprints from "@images/blueprints-image.avif";
import personWorking from "@images/person-working.avif";
import beforeAfter from "@images/before-after.avif";
import constructionWorkers from "@images/construction-workers.avif";
import aerialView from "@images/aerial-view.avif";
import usingTools from "@images/using-tools.avif";
import progressBuilding from "@images/progress-building.avif";
import underConstruction from "@images/under-construction.avif";
import { SITE } from "@data/constants";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Custom Development",
    subTitle:
      "As a neurodivergent developer specialized in productivity tools and passionate about UX/UI, I create custom solutions that enhance your digital workflow. From Obsidian plugins to Chrome extensions, each project is meticulously crafted to meet your specific needs while ensuring optimal performance and an intuitive user experience.",
    single: false,
    imgOne: blueprints,
    imgOneAlt: "Development workflow illustration",
    imgTwo: personWorking,
    imgTwoAlt: "Person working with digital tools",
  },
  {
    isRightSection: false,
    title: "Productivity Training",
    subTitle:
      "Transform your digital workflow with expert guidance. I offer personalized training sessions focused on productivity optimization, tool mastery, and workflow enhancement. Whether you're a beginner or advanced user, my approach adapts to your learning style and objectives.",
    img: beforeAfter,
    imgAlt: "Productivity training session",
    btnExists: true,
    btnTitle: "Learn More",
    btnURL: "#",
  },
  {
    isRightSection: true,
    title: "WordPress Expertise",
    subTitle:
      "Master WordPress with comprehensive training from basics to advanced features. I provide hands-on guidance for website creation, customization, and optimization. Learn to manage your content effectively while implementing best practices for performance and SEO.",
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: "WordPress development illustration",
    imgTwo: aerialView,
    imgTwoAlt: "Website management overview",
  },
  {
    isRightSection: false,
    title: "Software Implementation",
    subTitle:
      "Get personalized support for implementing and mastering essential software tools. From Obsidian to productivity apps, I help you optimize your digital workspace and establish efficient workflows tailored to your needs.",
    img: usingTools,
    imgAlt: "Software implementation demonstration",
  },
  {
    isRightSection: true,
    title: "Custom Solutions & Integration",
    subTitle:
      "Need a specific tool or workflow enhancement? I develop custom solutions that integrate seamlessly with your existing systems. From automation scripts to specialized plugins, I create tools that boost your productivity and streamline your work processes, always with a focus on exceptional user experience and interface design.",
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: "Custom development process",
    imgTwo: underConstruction,
    imgTwoAlt: "Integration workflow",
    btnExists: true,
    btnTitle: "Explore Solutions",
    btnURL: "#",
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://winflowz.com/services",
    "url": "https://winflowz.com/services",
    "name": "Digital Productivity Services & Training | WinFlowz",
    "description": "Expert development and training services for digital productivity enhancement. Custom plugins, extensions, and personalized coaching to optimize your workflow.",
    "isPartOf": {
        "@type": "WebSite",
        "url": "https://winflowz.com",
        "name": "WinFlowz",
        "description": "Digital productivity tools and training by a neurodivergent expert."
    },
    "inLanguage": "en-US"
  }}
>
  <MainSection
    title="Empowering Your Digital Productivity"
    subTitle="Transform your workflow with custom development and expert training. As a neurodivergent developer, UX/UI enthusiast, and productivity specialist, I offer tailored solutions and guidance to help you achieve peak efficiency in your digital workspace."
    btnExists={true}
    btnTitle="Schedule a Consultation"
    btnURL="#"
  />
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  <FeaturesStats
    title="Impact & Results"
    subTitle="My commitment to enhancing digital productivity is reflected in the success of my clients and the effectiveness of my solutions."
    mainStatTitle="96%"
    mainStatSubTitle="of clients report significant productivity improvements after implementation"
    stats={[
      {
        stat: "50+",
        description: "custom solutions delivered",
      },
      {
        stat: "200+",
        description: "productivity tips and techniques",
      },
      {
        stat: "85%",
        description: "time saved on repetitive tasks",
      },
    ]}
  />
</MainLayout>
