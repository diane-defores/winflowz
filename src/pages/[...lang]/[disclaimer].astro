---
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations, useUI } from '@/utils/i18n'
import type { Language } from '@/types'

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'disclaimer')
const ui = await useUI(lang)

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, disclaimer: 'disclaimer' } },
		{ params: { lang: 'fr', disclaimer: 'non-responsabilite' } },
	]
}
---

<MainLayout title={t.title} lang={lang}>
	<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
		<h1 class="mb-8 text-3xl font-bold text-neutral-900 dark:text-white">
			{t.title}
		</h1>

		<p class="mb-4 text-sm text-neutral-500 dark:text-neutral-400">
			{ui.common.lastUpdated}
		</p>

		<div class="space-y-6 text-neutral-600 dark:text-neutral-400">
			<!-- Section Informations Générales -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.general.title}
			</h2>
			<p>{t.sections.general.content}</p>

			<!-- Section Absence de Résultats Garantis -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.noGuarantee.title}
			</h2>
			<p>{t.sections.noGuarantee.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{
					t.sections.noGuarantee.items.map((item: string) => (
						<li>{item}</li>
					))
				}
			</ul>

			<!-- Section Limitations Techniques -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.technical.title}
			</h2>
			<p>{t.sections.technical.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{t.sections.technical.items.map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Conseil Professionnel -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.professional.title}
			</h2>
			<p>{t.sections.professional.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{
					t.sections.professional.items.map((item: string) => (
						<li>{item}</li>
					))
				}
			</ul>

			<!-- Section Contenu Tiers -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.thirdParty.title}
			</h2>
			<p>{t.sections.thirdParty.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{t.sections.thirdParty.items.map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Limitation de Responsabilité -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.liability.title}
			</h2>
			<p>{t.sections.liability.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{t.sections.liability.items.map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Modifications et Erreurs -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{t.sections.changes.title}
			</h2>
			<p>{t.sections.changes.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{t.sections.changes.items.map((item: string) => <li>{item}</li>)}
			</ul>
		</div>

		<p class="mt-8 text-sm text-neutral-500 dark:text-neutral-400">
			{t.contact}
		</p>
	</div>
</MainLayout>
