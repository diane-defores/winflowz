---
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import { getCollection } from 'astro:content'

export const prerender = true

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, services: 'services' } },
		{ params: { lang: 'fr', services: 'services' } },
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'services')

const services = await getCollection('services', ({ id }) => {
	return lang === 'fr' ? id.startsWith('fr/') : id.startsWith('en/')
})
---

<MainLayout title={t.title} lang={lang}>
	<div class="container mx-auto px-4 py-8">
		<h1 class="mb-8 text-4xl font-bold">{t.title}</h1>
		<div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
			{
				services.map((service) => (
					<div class="card bg-base-100 shadow-xl">
						<figure>
							<img
								src={service.data.image}
								alt={service.data.imageAlt}
								class="h-48 w-full object-cover"
							/>
						</figure>
						<div class="card-body">
							<h2 class="card-title">{service.data.title}</h2>
							<p>{service.data.description}</p>
							{service.data.features && (
								<ul class="mt-4 list-disc pl-5">
									{service.data.features.map((feature) => (
										<li class="text-sm">{feature}</li>
									))}
								</ul>
							)}
							<div class="card-actions justify-end">
								<a
									href={`/${lang}/services/${service.slug.replace(`${lang}/`, '')}`}
									class="btn btn-primary"
								>
									{t.learnMore}
								</a>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</MainLayout>
