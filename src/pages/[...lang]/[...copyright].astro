---
import MainLayout from "@/layouts/MainLayout.astro";
import { getLangFromUrl, useTranslations } from "@/utils/i18n";

export function getStaticPaths() {
  return [
    { params: { lang: undefined, copyright: "copyright" } },
    { params: { lang: "fr", copyright: "droits" } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang, "copyright");
---

<MainLayout
  title={t.title}
  lang={lang}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `https://winflowz.com/${lang === 'fr' ? 'fr/droits' : 'copyright'}`,
    "url": `https://winflowz.com/${lang === 'fr' ? 'fr/droits' : 'copyright'}`,
    "name": `${t.title} | WinFlowz`,
    "description": t.sections.protection.content,
    "inLanguage": lang
  }}
>
  <div class="max-w-4xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold mb-8 text-neutral-900 dark:text-white">
      {t.title}
    </h1>

    <p class="text-sm mb-4 text-neutral-500 dark:text-neutral-400">
      {t.lastUpdated}
    </p>

    <div class="space-y-6 text-neutral-600 dark:text-neutral-400">
      {/* Section Protection des Droits d'Auteur */}
      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">
        {t.sections.protection.title}
      </h2>
      <p>{t.sections.protection.content}</p>
      <ul class="list-disc pl-6 space-y-2">
        {t.sections.protection.items.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>

      {/* Section Restrictions de Licence */}
      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">
        {t.sections.license.title}
      </h2>
      <p>{t.sections.license.content}</p>
      <ul class="list-disc pl-6 space-y-2">
        {t.sections.license.items.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>

      {/* Section Utilisation Commerciale */}
      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">
        {t.sections.commercial.title}
      </h2>
      <p>{t.sections.commercial.content}</p>

      {/* Section Application */}
      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">
        {t.sections.enforcement.title}
      </h2>
      <p>{t.sections.enforcement.content}</p>
      <ul class="list-disc pl-6 space-y-2">
        {t.sections.enforcement.items.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>

      {/* Section Usage Équitable */}
      <h2 class="text-xl font-semibold mt-8 mb-4 text-neutral-800 dark:text-neutral-200">
        {t.sections.fairUse.title}
      </h2>
      <p>{t.sections.fairUse.content}</p>

      <p class="mt-8">
        {t.footer.notice}
      </p>
    </div>

    <p class="mt-8 text-sm text-neutral-500 dark:text-neutral-400">
      {t.footer.contact}
    </p>
  </div>
</MainLayout> 