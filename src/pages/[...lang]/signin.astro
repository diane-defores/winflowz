---
import MainLayout from '@/layouts/MainLayout.astro'
import type { Language } from '@/types'

export const prerender = true

export async function getStaticPaths() {
	return [
		{ params: { lang: undefined }, props: { lang: 'en' as Language } },
		{ params: { lang: 'fr' }, props: { lang: 'fr' as Language } },
	]
}

const { lang } = Astro.props
---

<MainLayout title="Sign In" lang={lang}>
	<div class="flex min-h-[60vh] items-center justify-center">
		<div class="text-center">
			<h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-4">
				Sign In
			</h1>
			<p class="text-neutral-500 dark:text-neutral-400 text-lg">
				Coming soon — Auth upgrade in progress.
			</p>
		</div>
	</div>
</MainLayout>
