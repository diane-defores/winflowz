---
import MainLayout from "@/layouts/MainLayout.astro";
import FeatureCard from "@/components/roadmap/FeatureCard.astro";
import ProjectNav from "@/components/roadmap/ProjectNav.astro";
import { projects } from "@/types/roadmap";
import { getLangFromUrl, useTranslations } from "@/utils/i18n";

export function getStaticPaths() {
  return [
    { params: { lang: undefined, roadmap: "roadmap" } },
    { params: { lang: "fr", roadmap: "roadmap" } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang, "roadmap");

// Fallback translations au cas où le chargement échoue
const defaultTranslations = {
  planned: "Planned",
  inProgress: "In Progress",
  completed: "Completed",
  considering: "Considering",
  inDevelopment: "In Development",
  vote: "Vote",
  votes: "votes"
};

const translations = {
  planned: t?.status?.planned ?? defaultTranslations.planned,
  inProgress: t?.status?.inProgress ?? defaultTranslations.inProgress,
  completed: t?.status?.completed ?? defaultTranslations.completed,
  considering: t?.status?.considering ?? defaultTranslations.considering,
  inDevelopment: t?.status?.inDevelopment ?? defaultTranslations.inDevelopment,
  vote: t?.feature?.vote ?? defaultTranslations.vote,
  votes: t?.feature?.votes ?? defaultTranslations.votes
};

const allFeatures = projects.flatMap(project => project.features);
---

<MainLayout title={t?.title ?? "Roadmap"} lang={lang}>
  <div class="min-h-screen bg-white dark:bg-neutral-900">
    <ProjectNav />
    
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">
          {t?.title ?? "Roadmap"}
        </h1>
        <p class="mt-2 text-lg leading-8 text-neutral-600 dark:text-neutral-400">
          {t?.subtitle ?? "Discover our projects and vote for the features you'd like to see implemented"}
        </p>
      </div>

      <div class="mt-16 space-y-20">
        {projects.map(project => (
          <section>
            <div class="mb-8">
              <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
                <a href={`/${lang ? `${lang}/` : ""}roadmap/${project.id}`} class="hover:text-orange-500 dark:hover:text-orange-400">
                  {t?.projects?.[project.id]?.name ?? project.name}
                </a>
              </h2>
              <p class="mt-2 text-lg text-neutral-600 dark:text-neutral-400">
                {t?.projects?.[project.id]?.description ?? project.description}
              </p>
            </div>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {project.features.map(feature => (
                <FeatureCard 
                  feature={feature} 
                  translations={translations}
                />
              ))}
            </div>
          </section>
        ))}
      </div>

      <section class="mt-20">
        <h2 class="mb-8 text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">
          {t?.sections?.allFeatures ?? "All Features"}
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {allFeatures
            .sort((a, b) => b.votes - a.votes)
            .map(feature => (
              <FeatureCard 
                feature={feature} 
                showProjectName={true}
                translations={translations}
              />
            ))}
        </div>
      </section>
    </div>
  </div>
</MainLayout> 