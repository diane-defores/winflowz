---
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations, useUI } from '@/utils/i18n'

export function getStaticPaths() {
	return [
		{ params: { lang: 'en', terms: 'terms' } },
		{ params: { lang: 'fr', terms: 'cgu' } },
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'terms')
const ui = await useUI(lang)

interface Section {
	title: string
	content?: string
	items?: string[]
}

type Terms = {
	sections: Record<string, Section>
}
---

<MainLayout title={t.title} lang={lang}>
	<main class="prose prose-lg container mx-auto max-w-4xl px-4 py-8">
		<h1 class="mb-6 text-4xl font-bold">{t.title}</h1>
		<p class="mb-8 text-gray-600">{ui.common.lastUpdated}</p>

		{
			Object.entries((t as Terms).sections).map(
				([key, section]: [string, Section]) => (
					<section class="mb-8">
						<h2 class="mb-4 text-2xl font-semibold">{section.title}</h2>
						{section.content && <p class="mb-4">{section.content}</p>}
						{section.items && (
							<ul class="list-disc space-y-2 pl-6">
								{section.items.map((item: string) => (
									<li>{item}</li>
								))}
							</ul>
						)}
					</section>
				)
			)
		}

		<footer class="mt-12 border-t border-gray-200 pt-8">
			<p class="text-gray-600">{t.contact}</p>
		</footer>
	</main>
</MainLayout>
