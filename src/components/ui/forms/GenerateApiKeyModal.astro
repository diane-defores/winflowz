---
import Modal from "../Modal.astro";
---

<Modal id="generate-api-key-modal" title="Générer une nouvelle clé API">
	<form action="/api/keys/generate" method="POST" class="space-y-6">
		<div>
			<label
				for="key-name"
				class="block text-sm font-medium text-neutral-700 dark:text-neutral-300"
			>
				Nom de la clé
			</label>
			<div class="mt-1">
				<input
					type="text"
					name="name"
					id="key-name"
					required
					class="block w-full rounded-md border-neutral-300 shadow-sm focus:border-neutral-500 focus:ring-neutral-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-100 sm:text-sm"
					placeholder="ex: Production API Key"
				/>
			</div>
			<p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
				Un nom descriptif pour identifier cette clé
			</p>
		</div>

		<div>
			<label
				for="expiration"
				class="block text-sm font-medium text-neutral-700 dark:text-neutral-300"
			>
				Expiration
			</label>
			<select
				id="expiration"
				name="expiration"
				class="mt-1 block w-full rounded-md border-neutral-300 py-2 pl-3 pr-10 text-base focus:border-neutral-500 focus:outline-none focus:ring-neutral-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-100 sm:text-sm"
			>
				<option value="never">Jamais</option>
				<option value="30d">30 jours</option>
				<option value="90d">90 jours</option>
				<option value="180d">180 jours</option>
				<option value="1y">1 an</option>
			</select>
		</div>

		<div>
			<label
				for="permissions"
				class="block text-sm font-medium text-neutral-700 dark:text-neutral-300"
			>
				Permissions
			</label>
			<div class="mt-2 space-y-2">
				<div class="flex items-center">
					<input
						id="read"
						name="permissions[]"
						type="checkbox"
						value="read"
						checked
						disabled
						class="h-4 w-4 rounded border-neutral-300 text-neutral-600 focus:ring-neutral-500 dark:border-neutral-600 dark:bg-neutral-700"
					/>
					<label
						for="read"
						class="ml-3 text-sm text-neutral-600 dark:text-neutral-400"
					>
						Lecture (requis)
					</label>
				</div>
				<div class="flex items-center">
					<input
						id="write"
						name="permissions[]"
						type="checkbox"
						value="write"
						class="h-4 w-4 rounded border-neutral-300 text-neutral-600 focus:ring-neutral-500 dark:border-neutral-600 dark:bg-neutral-700"
					/>
					<label
						for="write"
						class="ml-3 text-sm text-neutral-600 dark:text-neutral-400"
					>
						Écriture
					</label>
				</div>
			</div>
		</div>

		<div class="mt-6 flex justify-end space-x-3">
			<button
				type="button"
				class="rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-medium text-neutral-700 shadow-sm hover:bg-neutral-50 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-700"
				onclick="document.getElementById('generate-api-key-modal').close()"
			>
				Annuler
			</button>
			<button
				type="submit"
				class="inline-flex justify-center rounded-md border border-transparent bg-neutral-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-neutral-800 dark:bg-neutral-700 dark:hover:bg-neutral-600"
			>
				Générer
			</button>
		</div>
	</form>
</Modal>

<script>
	// Copier la clé dans le presse-papier
	document.querySelectorAll("[data-copy-key]").forEach((button) => {
		button.addEventListener("click", async () => {
			const key = button.getAttribute("data-copy-key");
			if (key) {
				try {
					await navigator.clipboard.writeText(key);
					// Afficher une notification de succès
				} catch (err) {
					console.error("Failed to copy:", err);
				}
			}
		});
	});
</script>

