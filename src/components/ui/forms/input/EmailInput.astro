---
interface Props {
  id: string;
  name: string;
  errorId: string;
  label?: string;
  placeholder?: string;
}

const { id, name, errorId, label = "Email address", placeholder = "Enter your email" } = Astro.props;
---

<div>
  <label for={id} class="mb-2 block text-sm text-neutral-800 dark:text-neutral-200">
    {label}
  </label>
  <div class="relative">
    <input
      type="email"
      id={id}
      name={name}
      class="block w-full rounded-lg border border-neutral-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-orange-500 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400"
      placeholder={placeholder}
      required
      aria-describedby={errorId}
    />
  </div>
  <p class="mt-2 hidden text-xs text-red-600" id={errorId}></p>
</div>
