---
// Destructure the properties from Astro.props
const { url, name } = Astro.props;

// Define TypeScript interface for the properties
interface Props {
  url: string;
  name: string;
}

// Détermine si le lien est actif
const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname === "/fr";
const isActive = 
  (url === "/" && isHome) || 
  (url !== "/" && pathname.includes(url.replace("/", "")));

// Classes de base et classes actives
const baseClasses = "rounded-lg text-base font-medium outline-none ring-zinc-500 focus-visible:ring dark:ring-zinc-200 dark:focus:outline-none md:py-3 md:text-sm 2xl:text-base";
const activeClasses = "text-orange-400 dark:text-orange-300";
const inactiveClasses = "text-neutral-600 dark:text-neutral-400 hover:text-neutral-500 dark:hover:text-neutral-500";
---

<a
  id={url === "/" ? "home" : url.replace("/", "")}
  href={url}
  data-astro-prefetch
  class:list={[baseClasses, isActive ? activeClasses : inactiveClasses]}
  aria-current={isActive ? "page" : undefined}
>
  {name}
</a>
