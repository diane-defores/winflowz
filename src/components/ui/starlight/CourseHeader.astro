import { Icon } from '@astrojs/starlight/components';

interface Props {
  frontmatter: {
    courseData?: {
      translations: {
        [key: string]: {
          title: string;
          description: string;
          objectives?: string[];
          prerequisites?: string[];
        };
      };
      duration?: string;
      level?: 'beginner' | 'intermediate' | 'advanced';
    };
  };
  lang: string;
}

const { frontmatter, lang } = Astro.props;
const courseData = frontmatter.courseData;

if (!courseData) return null;

const translations = courseData.translations[lang];

const levelColors = {
  beginner: 'text-green-500',
  intermediate: 'text-yellow-500',
  advanced: 'text-red-500',
};

const levelIcons = {
  beginner: 'ph:seedling-duotone',
  intermediate: 'ph:tree-duotone',
  advanced: 'ph:tree-evergreen-duotone',
};

const i18n = {
  en: {
    prerequisites: 'Prerequisites',
    objectives: 'Objectives',
  },
  fr: {
    prerequisites: 'Prérequis',
    objectives: 'Objectifs',
  },
};

<div class="course-header not-content">
  <div class="mb-8">
    {courseData.level && (
      <div class="flex items-center gap-2 mb-4">
        <Icon name={levelIcons[courseData.level]} class={`w-6 h-6 ${levelColors[courseData.level]}`} />
        <span class={`font-medium ${levelColors[courseData.level]}`}>
          {courseData.level.charAt(0).toUpperCase() + courseData.level.slice(1)}
        </span>
        {courseData.duration && (
          <>
            <span class="mx-2">•</span>
            <Icon name="ph:clock-duotone" class="w-5 h-5" />
            <span>{courseData.duration}</span>
          </>
        )}
      </div>
    )}
  </div>

  {translations.prerequisites && translations.prerequisites.length > 0 && (
    <div class="prerequisites mb-8">
      <h2 class="text-xl font-semibold mb-4">{i18n[lang].prerequisites}</h2>
      <ul class="list-disc list-inside space-y-2">
        {translations.prerequisites.map((prerequisite: string) => (
          <li>{prerequisite}</li>
        ))}
      </ul>
    </div>
  )}

  {translations.objectives && translations.objectives.length > 0 && (
    <div class="objectives mb-8">
      <h2 class="text-xl font-semibold mb-4">{i18n[lang].objectives}</h2>
      <ul class="list-disc list-inside space-y-2">
        {translations.objectives.map((objective: string) => (
          <li>{objective}</li>
        ))}
      </ul>
    </div>
  )}
</div>

<style>
  .course-header {
    @apply bg-slate-100 dark:bg-slate-800 rounded-lg p-6 mb-8;
  }
</style> 