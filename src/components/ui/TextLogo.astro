---
interface Props {
	class?: string
}

const { class: className } = Astro.props
---

<div class:list={['text-logo', className]}>
	<span class="text">WinFlowz</span>
	<div class="glow-effect"></div>
</div>

<script>
	const logos = document.querySelectorAll<HTMLElement>('.text-logo')

	document.addEventListener('mousemove', (e: MouseEvent) => {
		logos.forEach((card) => {
			const text = card.querySelector<HTMLElement>('.text')
			const glow = card.querySelector<HTMLElement>('.glow-effect')

			if (!text || !glow) return

			const rect = card.getBoundingClientRect()
			const cardCenterX = rect.left + rect.width / 2
			const cardCenterY = rect.top + rect.height / 2

			const distanceX = e.clientX - cardCenterX
			const distanceY = e.clientY - cardCenterY

			const maxDistance = 500
			const rotateX = Math.min(
				Math.max((distanceY / maxDistance) * 12, -12),
				12
			)
			const rotateY = Math.min(
				Math.max((-distanceX / maxDistance) * 12, -12),
				12
			)

			requestAnimationFrame(() => {
				card.style.transform = `perspective(1000px) rotateX(${rotateX * 0.5}deg) rotateY(${rotateY * 0.5}deg)`
				text.style.transform = `translateZ(20px) rotateX(${rotateX * 0.8}deg) rotateY(${rotateY * 0.8}deg)`
				glow.style.transform = `translateZ(10px) rotateX(${rotateX * 0.2}deg) rotateY(${rotateY * 0.2}deg)`
			})
		})
	})

	document.addEventListener('mouseleave', () => {
		logos.forEach((card) => {
			const text = card.querySelector<HTMLElement>('.text')
			const glow = card.querySelector<HTMLElement>('.glow-effect')

			if (!text || !glow) return

			requestAnimationFrame(() => {
				card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)'
				text.style.transform = 'translateZ(0) rotateX(0) rotateY(0)'
				glow.style.transform = 'translateZ(0) rotateX(0) rotateY(0)'
			})
		})
	})
</script>

<style>
	@font-face {
		font-family: 'Audiowide';
		src: url('/fonts/Audiowide-Regular.woff2') format('woff2');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	.text-logo {
		font-family: 'Audiowide', sans-serif;
		font-size: 2.5rem;
		font-weight: bold;
		display: inline-flex;
		align-items: center;
		position: relative;
		transform-style: preserve-3d;
		perspective: 1000px;
		cursor: pointer;
		transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		will-change: transform;
	}

	.text {
		position: relative;
		color: white;
		transform-style: preserve-3d;
		transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		will-change: transform;
		filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
	}

	.text::before {
		content: 'WinFlowz';
		position: absolute;
		inset: 0;
		background-image: linear-gradient(
				45deg,
				#ff0033,
				#ff00c8,
				#ffe500,
				#00ff44,
				#00c8ff,
				#ff0033
			),
			radial-gradient(
				circle at top left,
				#ff0033,
				#ff3366,
				#ff00c8,
				#ff33cc,
				#ffe500,
				#ffcc00,
				#00ff44,
				#00cc44,
				#00c8ff,
				#0099ff,
				#ff0033
			);
		background-size: 200% 200%;
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		animation: gradient 6s ease infinite;
		transform: translateZ(8px);
		transition: all 0.3s ease;
		filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.4));
	}

	.text::after {
		content: 'WinFlowz';
		position: absolute;
		left: 1px;
		top: 1px;
		color: white;
		z-index: -1;
		transform: translateZ(4px);
		text-shadow:
			0.5px 0.5px 0 white,
			1px 1px 0 white,
			1.5px 1.5px 0 rgba(255, 255, 255, 0.7),
			0 2px 5px rgba(0, 0, 0, 0.2);
	}

	.glow-effect {
		position: absolute;
		inset: -6px -10px;
		background: linear-gradient(
				45deg,
				#ff0033,
				#ff00c8,
				#ffe500,
				#00ff44,
				#00c8ff,
				#ff0033
			),
			radial-gradient(
				circle at top left,
				#ff0033,
				#ff3366,
				#ff00c8,
				#ff33cc,
				#ffe500,
				#ffcc00,
				#00ff44,
				#00cc44,
				#00c8ff,
				#0099ff,
				#ff0033
			);
		background-size: 200% 200%;
		filter: blur(12px);
		opacity: 0.3;
		border-radius: 40% / 100%;
		animation: gradient 6s ease infinite;
		z-index: -2;
		transform-style: preserve-3d;
		transition: all 0.3s ease;
		box-shadow:
			0 0 10px rgba(255, 0, 200, 0.3),
			0 0 20px rgba(0, 200, 255, 0.2);
	}

	.text-logo:hover .text {
		filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
	}

	.text-logo:hover .glow-effect {
		opacity: 0.45;
		filter: blur(15px);
		animation: gradient 4s ease infinite;
	}

	.text-logo:hover .text::before {
		transform: translateZ(12px);
		filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.5));
	}

	.text-logo:hover .text::after {
		transform: translateZ(6px);
		left: 1.5px;
		top: 1.5px;
		text-shadow:
			1px 1px 0 white,
			1.5px 1.5px 0 white,
			2px 2px 0 rgba(255, 255, 255, 0.7),
			0 4px 8px rgba(0, 0, 0, 0.3);
	}

	.text-logo:hover .shadow-layer {
		display: none;
	}

	@keyframes gradient {
		0% {
			background-position: 0% 50%;
		}
		50% {
			background-position: 100% 50%;
		}
		100% {
			background-position: 0% 50%;
		}
	}

	@keyframes rotate {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	@keyframes pulseGlow {
		0%,
		100% {
			transform: scale(1) translateZ(-10px);
			filter: blur(12px);
			border-radius: 45% / 100%;
		}
		50% {
			transform: scale(1.1) translateZ(-10px);
			filter: blur(14px);
			border-radius: 35% / 100%;
		}
	}

	/* Windows-like focus effect */
	.text-logo:active .text {
		filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.2));
	}

	.text-logo:active .glow-effect {
		opacity: 0.5;
		transform: rotate(180deg) scale(0.95);
		animation-play-state: paused;
	}

	.text-logo:active .text::before {
		transform: translateZ(6px);
		filter: drop-shadow(0 0 3px rgba(255, 255, 255, 0.3));
	}

	.text-logo:active .text::after {
		transform: translateZ(3px);
		left: 0.5px;
		top: 0.5px;
		text-shadow:
			0.5px 0.5px 0 white,
			0.75px 0.75px 0 white,
			1px 1px 0 rgba(255, 255, 255, 0.7),
			0 1px 3px rgba(0, 0, 0, 0.15);
	}

	.text-logo:active .shadow-layer {
		display: none;
	}

	/* Responsive design */
	@media (max-width: 640px) {
		.text-logo {
			font-size: 2rem;
		}
		.glow-effect {
			inset: -5px -8px;
		}
	}

	@media (max-width: 480px) {
		.text-logo {
			font-size: 1.5rem;
		}
		.glow-effect {
			inset: -4px -6px;
		}
	}
</style>
