---
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

interface FooterLink {
	name: string
	url: string
}

interface FooterSection {
	section: string
	links: FooterLink[]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'navigation')
const homeUrl = lang === 'fr' ? '/fr' : '/'

const footerSections:
	Array<{ title: string; links: Array<{ label: string; href: string }> }> =
	t.footerLinks?.map((section: FooterSection) => ({
		title: section.section,
		links: section.links.map((link: FooterLink) => ({
			label: link.name,
			href: link.url,
		})),
	})) || []

const newsletterTitle =
	t.newsletterSection?.title || 'This Week In Windows Productivity'
const newsletterDesc =
	t.newsletterSection?.description ||
	'Weekly newsletter about Windows tooling and the productivity ecosystem.'
const craftedBy = t.footer?.crafted || 'Crafted by'
const githubUrl = t.socialLinks?.github || 'https://github.com/dianedef/winflowz'
const currentYear = new Date().getFullYear()
---

<footer class="border-t border-neutral-200 bg-neutral-50 dark:border-zinc-800 dark:bg-black">
	<div class="mx-auto max-w-6xl px-4 py-16">
		<div class="reveal grid grid-cols-2 gap-8 md:grid-cols-5">
			<div class="col-span-2 md:col-span-1">
				<a href={homeUrl} class="mb-4 flex items-center gap-2 no-hover-animation">
					<div class="text-logo" style="font-size: 1.25rem;">
						<span class="text">WinFlowz</span>
						<div class="glow-effect"></div>
					</div>
				</a>
				<p class="mb-4 text-sm text-neutral-500 dark:text-zinc-500">
					Productivity plugins & Windows training by Diane Defores.
				</p>
				<div class="mb-4">
					<p class="mb-2 text-xs text-neutral-600 dark:text-zinc-400">
						{newsletterTitle}
					</p>
					<p class="text-xs text-neutral-500 dark:text-zinc-500">
						{newsletterDesc}
					</p>
				</div>
				<div class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-neutral-100 px-3 py-1.5 dark:border-zinc-800 dark:bg-zinc-900">
					<span
						class="pulse-glow h-2 w-2 rounded-full"
						style="background-color: var(--brand-green);"
					></span>
					<span class="text-xs text-neutral-500 dark:text-zinc-400">
						All Systems Operational
					</span>
				</div>
			</div>

			{
				footerSections.map((section) => (
					<div>
						<h4 class="mb-4 text-sm font-semibold text-neutral-900 dark:text-white">
							{section.title}
						</h4>
						<ul class="space-y-3">
							{section.links.map((link) => (
								<li>
									<a
										href={link.href}
										class="text-sm text-neutral-500 transition-colors hover:text-neutral-900 dark:text-zinc-500 dark:hover:text-white"
									>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="reveal delay-3 mt-16 flex flex-col items-center justify-between gap-4 border-t border-neutral-200 pt-8 dark:border-zinc-800 sm:flex-row">
			<p class="text-sm text-neutral-500 dark:text-zinc-500">
				&copy; {currentYear} WinFlowz. {craftedBy} Diane Defores.
			</p>
			<div class="flex items-center gap-6">
				<a
					href={githubUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="text-sm text-neutral-500 transition-colors hover:text-neutral-900 dark:text-zinc-500 dark:hover:text-white"
				>
					GitHub
				</a>
				<a
					href="mailto:contact@winflowz.com"
					class="text-sm text-neutral-500 transition-colors hover:text-neutral-900 dark:text-zinc-500 dark:hover:text-white"
				>
					Contact
				</a>
			</div>
		</div>
	</div>
</footer>
