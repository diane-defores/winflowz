---
import LoginModal from '@components/ui/forms/LoginModal.astro'
import RegisterModal from '@components/ui/forms/RegisterModal.astro'
import RecoverModal from '@components/ui/forms/RecoverModal.astro'
import LoginBtn from '@components/ui/buttons/LoginBtn.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'auth')

const dashboardUrl = lang === 'fr' ? '/fr/dashboard' : '/dashboard'
---

<div id="auth-container">
	<LoginBtn />
	<LoginModal />
	<RegisterModal />
	<RecoverModal />
</div>

<script>
	import { getCurrentUser } from '@/lib/auth'

	async function renderUserMenu() {
		const container = document.getElementById('auth-container')
		const user = await getCurrentUser()

		if (!user || !container) return

		container.innerHTML = `
      <div class="hs-dropdown relative inline-flex">
        <button
          id="hs-dropdown-custom-trigger"
          type="button"
          class="hs-dropdown-toggle flex items-center gap-2 rounded-full bg-neutral-100 p-1 hover:bg-neutral-200 dark:bg-neutral-800 dark:hover:bg-neutral-700"
        >
          <img
            class="h-8 w-8 rounded-full"
            src="https://api.dicebear.com/7.x/avataaars/svg?seed=${user.email}"
            alt="Avatar"
          />
          <span class="font-medium text-neutral-700 dark:text-neutral-200">
            ${user.email?.split('@')[0]}
          </span>
          <svg
            class="h-4 w-4 text-neutral-600 dark:text-neutral-400"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </button>

        <div
          class="hs-dropdown-menu duration hs-dropdown-open:opacity-100 fixed z-10 mt-2 hidden min-w-[15rem] rounded-lg bg-white p-2 opacity-0 shadow-md transition-[opacity,margin] dark:border dark:border-neutral-700 dark:bg-neutral-800"
          aria-labelledby="hs-dropdown-custom-trigger"
        >
          <a
            class="flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-neutral-800 hover:bg-neutral-100 focus:outline-none dark:text-neutral-200 dark:hover:bg-neutral-700 dark:hover:text-neutral-200"
            href="${dashboardUrl}"
          >
            <svg
              class="h-4 w-4"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z"></path>
              <path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4"></path>
            </svg>
            Dashboard
          </a>
          <a
            class="flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-neutral-800 hover:bg-neutral-100 focus:outline-none dark:text-neutral-200 dark:hover:bg-neutral-700 dark:hover:text-neutral-200"
            href="${dashboardUrl}/parametres"
          >
            <svg
              class="h-4 w-4"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            Paramètres
          </a>
          <div class="my-2 border-t border-neutral-200 dark:border-neutral-700"></div>
          <button
            id="logout-button"
            class="flex w-full items-center gap-x-3.5 rounded-lg px-3 py-2 text-red-600 hover:bg-neutral-100 focus:outline-none dark:text-red-500 dark:hover:bg-neutral-700"
          >
            <svg
              class="h-4 w-4"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Déconnexion
          </button>
        </div>
      </div>
    `

		// Réinitialiser les composants Preline
		// @ts-ignore
		HSDropdown.autoInit()

		// Ajouter l'écouteur de déconnexion
		const logoutButton = document.getElementById('logout-button')
		if (logoutButton) {
			logoutButton.addEventListener('click', async () => {
				try {
					const { signOut } = await import('@/lib/auth')
					const { error } = await signOut()
					if (error) throw error
					window.location.href = '/'
				} catch (err) {
					console.error('Erreur lors de la déconnexion:', err)
				}
			})
		}
	}

	// Initialiser au chargement de la page
	document.addEventListener('astro:page-load', renderUserMenu)
</script>

