---
const { t } = Astro.props;
---

<section class="py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-6xl">
        {t.hero.title}
      </h1>
      <p class="mt-6 text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        {t.hero.subtitle}
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-4xl grid-cols-1 gap-8 sm:mt-20 lg:grid-cols-2">
      <!-- Formulaire de Contact -->
      <div class="rounded-2xl bg-white p-8 shadow-lg ring-1 ring-neutral-900/5 dark:bg-neutral-800 dark:ring-white/10">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-neutral-900 dark:text-white">
              {t.form.name.label}
            </label>
            <input
              type="text"
              name="name"
              id="name"
              placeholder={t.form.name.placeholder}
              class="mt-2 block w-full rounded-md border-0 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-orange-600 dark:bg-neutral-700 dark:text-white dark:ring-neutral-600 dark:placeholder:text-neutral-500 dark:focus:ring-orange-500 sm:text-sm sm:leading-6"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-neutral-900 dark:text-white">
              {t.form.email.label}
            </label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder={t.form.email.placeholder}
              class="mt-2 block w-full rounded-md border-0 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-orange-600 dark:bg-neutral-700 dark:text-white dark:ring-neutral-600 dark:placeholder:text-neutral-500 dark:focus:ring-orange-500 sm:text-sm sm:leading-6"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-neutral-900 dark:text-white">
              {t.form.subject.label}
            </label>
            <input
              type="text"
              name="subject"
              id="subject"
              placeholder={t.form.subject.placeholder}
              class="mt-2 block w-full rounded-md border-0 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-orange-600 dark:bg-neutral-700 dark:text-white dark:ring-neutral-600 dark:placeholder:text-neutral-500 dark:focus:ring-orange-500 sm:text-sm sm:leading-6"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-neutral-900 dark:text-white">
              {t.form.message.label}
            </label>
            <textarea
              name="message"
              id="message"
              rows="4"
              placeholder={t.form.message.placeholder}
              class="mt-2 block w-full rounded-md border-0 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-orange-600 dark:bg-neutral-700 dark:text-white dark:ring-neutral-600 dark:placeholder:text-neutral-500 dark:focus:ring-orange-500 sm:text-sm sm:leading-6"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-md bg-orange-600 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-orange-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600 dark:bg-orange-500 dark:hover:bg-orange-400"
          >
            {t.form.submit}
          </button>
        </form>
      </div>

      <!-- Informations de Contact -->
      <div class="space-y-10">
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
            {t.contact.title}
          </h2>
          <dl class="mt-4 space-y-4">
            <div>
              <dt class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
                {t.contact.email.label}
              </dt>
              <dd class="mt-1">
                <a
                  href={`mailto:${t.contact.email.value}`}
                  class="text-orange-600 hover:text-orange-500 dark:text-orange-500 dark:hover:text-orange-400"
                >
                  {t.contact.email.value}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
                {t.contact.location.label}
              </dt>
              <dd class="mt-1 text-neutral-900 dark:text-white">
                {t.contact.location.value}
              </dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
                {t.contact.hours.label}
              </dt>
              <dd class="mt-1 text-neutral-900 dark:text-white">
                {t.contact.hours.value}
              </dd>
            </div>
          </dl>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
            {t.support.title}
          </h2>
          <ul class="mt-4 space-y-4">
            {t.support.items.map((item) => (
              <li>
                <a
                  href={item.link}
                  class="group flex items-start space-x-3 text-neutral-600 hover:text-orange-600 dark:text-neutral-400 dark:hover:text-orange-500"
                >
                  <div>
                    <p class="font-medium text-neutral-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-500">
                      {item.title}
                    </p>
                    <p class="mt-1 text-sm">{item.description}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section> 