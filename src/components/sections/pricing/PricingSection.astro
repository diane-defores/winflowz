---
import { getLangFromUrl, useTranslations } from "@/utils/i18n";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang, "pricing");

interface Plan {
  name: string;
  description: string;
  price: string;
  period: string;
  features: string[];
  cta: string;
  popular?: boolean;
}

interface PricingTranslations {
  title: string;
  subtitle: string;
  plans: Plan[];
}
---

<section class="mx-auto max-w-[85rem] px-3 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-14">
  <!-- Section heading and sub-heading -->
  <div class="mx-auto mb-8 max-w-2xl text-center sm:mb-10 lg:mb-14">
    <h2 class="text-balance text-xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-2xl md:text-4xl md:leading-tight">
      {t.title}
    </h2>
    <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
      {t.subtitle}
    </p>
  </div>

  <!-- Contains two main product blocks -->
  <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4 md:gap-0">
    <!-- Starter Kit product details -->
    <div class="w-full rounded-xl bg-gray-800 p-4 sm:w-1/2 sm:rounded-r-none sm:p-6 lg:w-1/3 lg:p-8">
      <div class="mb-3 sm:mb-4">
        <h3 class="text-xl font-bold text-neutral-100 sm:text-2xl md:text-3xl">
          {t.plans[0].name}
        </h3>
        <p class="text-indigo-300">{t.plans[0].description}</p>
      </div>

      <div class="mb-3 sm:mb-4">
        <span class="text-3xl font-bold text-neutral-200 sm:text-4xl">{t.plans[0].price}</span>
        {t.plans[0].period && (
          <span class="ms-3 text-sm text-indigo-200">{t.plans[0].period}</span>
        )}
      </div>

      <ul class="mb-4 space-y-2 text-sm text-neutral-300 sm:mb-6 sm:text-base">
        {t.plans[0].features.map((feature: string) => (
          <li class="flex items-center gap-1.5">
            <svg class="h-5 w-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span>{feature}</span>
          </li>
        ))}
      </ul>

      <a
        href="#"
        class="block rounded-lg bg-gray-500 px-6 py-2.5 text-center text-sm font-bold text-gray-100 outline-none ring-indigo-300 transition duration-100 hover:bg-gray-600 focus-visible:ring active:text-gray-300 sm:px-8 sm:py-3 md:text-base"
      >
        {t.plans[0].cta}
      </a>
    </div>

    <!-- Pro product details -->
    <div class="w-full rounded-xl bg-gradient-to-tr from-[#FF512F] to-[#F09819] p-4 shadow-xl sm:w-1/2 sm:p-6 lg:p-8">
      <div class="mb-3 flex flex-col items-start justify-between gap-3 sm:mb-4 sm:gap-4 lg:flex-row">
        <div>
          <h3 class="text-xl font-bold text-neutral-100 sm:text-2xl md:text-3xl">
            {t.plans[1].name}
          </h3>
          <p class="text-orange-200">{t.plans[1].description}</p>
        </div>

        <span class="order-first inline-block rounded-full bg-orange-200 bg-opacity-50 px-3 py-1 text-xs font-bold uppercase tracking-wider text-center text-orange-600 lg:order-none">
          {lang === "fr" ? "Populaire" : "Popular"}
        </span>
      </div>

      <div class="mb-3 sm:mb-4">
        <span class="text-4xl font-bold text-neutral-100 sm:text-5xl md:text-6xl">{t.plans[1].price}</span>
        {t.plans[1].period && (
          <span class="ms-3 text-orange-200">{t.plans[1].period}</span>
        )}
      </div>

      <ul class="mb-4 space-y-2 text-sm text-orange-100 sm:mb-6 sm:text-base">
        {t.plans[1].features.map((feature: string) => (
          <li class="flex items-center gap-1.5">
            <svg class="h-5 w-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span>{feature}</span>
          </li>
        ))}
      </ul>

      <a
        href="#"
        class="block rounded-lg bg-orange-200 bg-opacity-50 px-6 py-2.5 text-center text-sm font-bold text-neutral-100 outline-none ring-orange-300 transition duration-100 hover:bg-orange-300 hover:bg-opacity-50 focus-visible:ring active:bg-orange-400 sm:px-8 sm:py-3 md:text-base"
      >
        {t.plans[1].cta}
      </a>
    </div>
  </div>

  <!-- Enterprise CTA -->
  <div class="mt-6 flex items-center justify-center gap-x-3 sm:mt-8 md:mt-12">
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      {t.plans[2].description}
    </p>
    <SecondaryCTA title={t.plans[2].cta} url="#" />
  </div>
</section>
