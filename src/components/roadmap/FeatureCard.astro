---
import type { Feature } from "@/types/roadmap";
import { Icon } from "astro-icon/components";
import StatusIcon from "./StatusIcon.astro";

interface Props {
  feature: Feature & {
    projectName?: string;
  };
  showProjectName?: boolean;
  translations: {
    planned: string;
    inProgress: string;
    completed: string;
    considering: string;
    vote: string;
    votes: string;
  };
}

const { feature, showProjectName = false, translations } = Astro.props;

function getStatusColor(status: Feature["status"]) {
  switch (status) {
    case "in-development":
      return "text-blue-600 bg-blue-50 dark:bg-blue-900/20 dark:text-blue-400";
    case "planned":
      return "text-yellow-600 bg-yellow-50 dark:bg-yellow-900/20 dark:text-yellow-400";
    case "considering":
      return "text-purple-600 bg-purple-50 dark:bg-purple-900/20 dark:text-purple-400";
    case "completed":
      return "text-green-600 bg-green-50 dark:bg-green-900/20 dark:text-green-400";
    default:
      return "text-neutral-600 bg-neutral-50 dark:bg-neutral-900/20 dark:text-neutral-400";
  }
}

function getStatusTitle(status: Feature["status"]) {
  switch (status) {
    case "in-development":
      return translations.inProgress;
    case "planned":
      return translations.planned;
    case "considering":
      return translations.considering;
    case "completed":
      return translations.completed;
    default:
      return status;
  }
}
---

<div class="relative flex flex-col overflow-hidden rounded-lg border border-neutral-200 bg-white shadow-sm transition-all hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900">
  <div class="flex flex-1 flex-col justify-between p-6">
    <div class="flex-1">
      {showProjectName && feature.projectName && (
        <p class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
          {feature.projectName}
        </p>
      )}
      <div class="mt-2 block">
        <p class="text-xl font-semibold text-neutral-900 dark:text-white">
          {feature.title}
        </p>
        <p class="mt-3 text-base text-neutral-500 dark:text-neutral-400">
          {feature.description}
        </p>
      </div>
    </div>

    <div class="mt-6 flex items-center justify-between">
      <div class="flex items-center">
        <span
          class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium ${getStatusColor(
            feature.status
          )}`}
        >
          <StatusIcon status={feature.status} />
          {getStatusTitle(feature.status)}
        </span>
      </div>
      <div class="flex items-center space-x-1">
        <button
          type="button"
          class="inline-flex items-center space-x-1 rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm font-semibold text-neutral-900 shadow-sm hover:bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 dark:text-white dark:hover:bg-neutral-800"
          data-feature-id={feature.id}
          data-vote-button
        >
          <Icon name="mdi:thumb-up-outline" class="h-5 w-5" />
          <span>{translations.vote}</span>
          <span class="ml-0.5 text-neutral-500">({feature.votes})</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const voteButtons = document.querySelectorAll('[data-vote-button]');
    
    voteButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const featureId = button.getAttribute('data-feature-id');
        const voteCount = button.closest('button')?.querySelector('.text-neutral-500');
        
        if (!featureId || !voteCount) return;
        
        try {
          const response = await fetch(`/api/features/${featureId}/vote`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          if (response.ok) {
            const data = await response.json();
            voteCount.textContent = `(${data.votes})`;
            
            // Ajouter une petite animation
            button.classList.add('scale-105');
            setTimeout(() => button.classList.remove('scale-105'), 200);
          }
        } catch (error) {
          console.error('Error voting:', error);
        }
      });
    });
  });
</script> 