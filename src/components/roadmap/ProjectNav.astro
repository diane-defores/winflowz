---
import { projects } from "../../types/roadmap";

interface Props {
  currentProjectId?: string;
}

const { currentProjectId } = Astro.props;
---

<nav class="sticky top-0 z-50 border-b border-neutral-200 bg-white/80 backdrop-blur-sm dark:border-neutral-800 dark:bg-neutral-900/80">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-center gap-4">
      <a 
        href="/roadmap"
        class:list={[
          "group relative flex h-10 min-w-[140px] items-center justify-center rounded-lg border-2 px-3 py-1.5 text-sm font-semibold transition-all duration-300",
          !currentProjectId ? 
            "border-orange-500 bg-orange-50 text-orange-600 ring-2 ring-orange-500/20 dark:border-orange-400 dark:bg-orange-400/10 dark:text-orange-300 dark:ring-orange-400/10" : 
            "border-neutral-200 bg-white text-neutral-600 hover:border-orange-500 hover:bg-orange-50 hover:text-orange-600 hover:ring-2 hover:ring-orange-500/20 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:border-orange-400 dark:hover:bg-orange-400/10 dark:hover:text-orange-300 dark:hover:ring-orange-400/10"
        ]}
      >
        <span class="relative">
          Tous les projets
        </span>
      </a>

      {projects.map(project => (
        <a
          href={`/roadmap/${project.id}`}
          class:list={[
            "group relative flex h-10 min-w-[140px] items-center justify-center rounded-lg border-2 px-3 py-1.5 text-sm font-semibold transition-all duration-300",
            currentProjectId === project.id ? 
              "border-orange-500 bg-orange-50 text-orange-600 ring-2 ring-orange-500/20 dark:border-orange-400 dark:bg-orange-400/10 dark:text-orange-300 dark:ring-orange-400/10" : 
              "border-neutral-200 bg-white text-neutral-600 hover:border-orange-500 hover:bg-orange-50 hover:text-orange-600 hover:ring-2 hover:ring-orange-500/20 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:border-orange-400 dark:hover:bg-orange-400/10 dark:hover:text-orange-300 dark:hover:ring-orange-400/10"
          ]}
        >
          <span class="relative">
            {project.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</nav> 