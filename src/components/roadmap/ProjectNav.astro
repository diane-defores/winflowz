---
import { projects } from "@/types/roadmap";
import { getLangFromUrl, useTranslations } from "@/utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang, "roadmap");

const currentPath = Astro.url.pathname;
---

<div class="border-b border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-900">
	<nav class="mx-auto flex max-w-7xl gap-x-8 gap-y-2 px-4 py-4 sm:px-6 lg:px-8" aria-label={t?.nav?.projectsLabel ?? "Projects navigation"}>
		<a
			href={lang === "fr" ? `/fr/roadmap` : `/roadmap`}
			class:list={[
				"text-sm font-medium transition-colors",
				currentPath === (lang === "fr" ? `/fr/roadmap` : `/roadmap`)
					? "text-orange-500 dark:text-orange-400"
					: "text-neutral-700 hover:text-orange-500 dark:text-neutral-300 dark:hover:text-orange-400",
			]}
		>
			{t?.sections?.allProjects ?? "All Projects"}
		</a>
		{
			projects.map((project) => (
				<a
					href={lang === "fr" ? `/fr/roadmap/${project.id}` : `/roadmap/${project.id}`}
					class:list={[
						"text-sm font-medium transition-colors",
						currentPath.includes(project.id)
							? "text-orange-500 dark:text-orange-400"
							: "text-neutral-700 hover:text-orange-500 dark:text-neutral-300 dark:hover:text-orange-400",
					]}
				>
					{t?.projects?.[project.id]?.name ?? project.name}
				</a>
			))
		}
	</nav>
</div>

