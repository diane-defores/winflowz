---
import { projects } from "@/types/roadmap";
import { getLangFromUrl, useTranslations } from "@/utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang, "roadmap");

const currentPath = Astro.url.pathname;
const currentProjectId = currentPath.split('/').pop();
---

<div class="mt-8 border-b border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-900">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center justify-center gap-4">
			<a
				href={lang === "fr" ? `/fr/roadmap` : `/roadmap`}
				class:list={[
					"group relative flex h-10 min-w-[140px] items-center justify-center rounded-lg border-2 px-3 py-1.5 text-sm font-semibold transition-all duration-300",
					!currentProjectId
						? "bg-orange-50 border-orange-500 text-orange-600 ring-2 ring-orange-500/20 dark:border-orange-400 dark:bg-orange-400/10 dark:text-orange-300 dark:ring-orange-400/10"
						: "hover:bg-orange-50 border-neutral-200 bg-white text-neutral-600 hover:border-orange-500 hover:text-orange-600 hover:ring-2 hover:ring-orange-500/20 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:border-orange-400 dark:hover:bg-orange-400/10 dark:hover:text-orange-300 dark:hover:ring-orange-400/10",
				]}
				data-astro-prefetch
			>
				<span class="relative">{t?.sections?.allProjects ?? "Tous les projets"}</span>
			</a>

			{projects.map((project) => (
				<a
					href={lang === "fr" ? `/fr/roadmap/${project.id}` : `/roadmap/${project.id}`}
					class:list={[
						"group relative flex h-10 min-w-[140px] items-center justify-center rounded-lg border-2 px-3 py-1.5 text-sm font-semibold transition-all duration-300",
						currentProjectId === project.id
							? "bg-orange-50 border-orange-500 text-orange-600 ring-2 ring-orange-500/20 dark:border-orange-400 dark:bg-orange-400/10 dark:text-orange-300 dark:ring-orange-400/10"
							: "hover:bg-orange-50 border-neutral-200 bg-white text-neutral-600 hover:border-orange-500 hover:text-orange-600 hover:ring-2 hover:ring-orange-500/20 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:border-orange-400 dark:hover:bg-orange-400/10 dark:hover:text-orange-300 dark:hover:ring-orange-400/10",
					]}
					data-astro-prefetch
				>
					<span class="relative">{t?.projects?.[project.id]?.name ?? project.name}</span>
				</a>
			))}

			<button
				type="button"
				data-hs-overlay="#addFeatureModal"
				class="dark:hover:bg-orange-700 flex h-10 items-center gap-2 rounded-lg bg-orange-500 px-4 text-sm font-medium text-white transition-colors hover:bg-orange-600 dark:bg-orange-600"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke-width="1.5"
					stroke="currentColor"
					class="h-5 w-5"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M12 4.5v15m7.5-7.5h-15"
					/>
				</svg>
				<span>{t?.addFeature?.button ?? "Add Feature"}</span>
			</button>
		</div>
	</div>
</div>

