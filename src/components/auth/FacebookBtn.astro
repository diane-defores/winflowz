---
interface Props {
	class?: string
	redirectTo?: string
}

const { class: className = '', redirectTo } = Astro.props
---

<button
	type="button"
	class:list={[
		'btn flex w-full items-center gap-2 bg-[#1877F2] text-white hover:bg-[#0C63D4]',
		className,
	]}
	data-provider="facebook"
	data-redirect-to={redirectTo}
	onclick="handleOAuthLogin(this)"
>
	<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
		<path
			d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
		></path>
	</svg>
	<span>Continuer avec Facebook</span>
</button>

<script>
	async function handleOAuthLogin(button: HTMLButtonElement) {
		try {
			const provider = button.dataset.provider
			const redirectTo = button.dataset.redirectTo

			const response = await fetch(`/api/auth/oauth/${provider}`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ redirectTo }),
			})

			if (!response.ok) {
				const error = await response.json()
				throw new Error(error.message || 'Erreur de connexion OAuth')
			}

			// La redirection sera gérée par l'API
		} catch (error) {
			console.error('Erreur lors de la connexion OAuth:', error)
			// Gérer l'erreur (afficher un message à l'utilisateur, etc.)
		}
	}

	// Exposer la fonction pour qu'elle soit accessible depuis le HTML
	window.handleOAuthLogin = handleOAuthLogin
</script>

<script>
	// TypeScript : déclarer la fonction globale
	declare global {
		interface Window {
			handleOAuthLogin: (button: HTMLButtonElement) => Promise<void>
		}
	}
</script>

