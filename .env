# Configuration Supabase (remplacer dans .env.local)
PUBLIC_SUPABASE_URL=votre_url_projet
PUBLIC_SUPABASE_PUBLISHABLE_KEY="votre-cle-publishable"
PUBLIC_SUPABASE_ANON_KEY=votre_clé_anon
SUPABASE_SERVICE_ROLE_KEY=votre_clé_service_role

# URLs de redirection OAuth (à configurer dans la console Supabase)
PUBLIC_AUTH_REDIRECT_URL=http://localhost:4327/auth/callback

# Configuration des cookies
COOKIE_DOMAIN=localhost
SECURE_COOKIE=false # Mettre à true en production

# URL du site
PUBLIC_SITE_URL="http://localhost:4327"

# Configuration OAuth
PUBLIC_OAUTH_PROVIDERS=google,github,facebook
PUBLIC_FACEBOOK_CLIENT_ID=votre_facebook_app_id