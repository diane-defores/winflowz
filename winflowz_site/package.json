{
  "name": "winflowz",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "clean": "rimraf dist .vercel/output node_modules/.vite",
    "typecheck": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro check --tsconfig ./tsconfig.json",
    "build:check": "astro check --tsconfig ./tsconfig.json",
    "build:analyze": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build --analyze",
    "build:astro": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build",
    "build:debug": "set NODE_OPTIONS=\"--inspect --inspect-brk\" && astro build",
    "build": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build --force",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "pnpm build && vitest run tests/auth/integration",
    "test:e2e": "pnpm build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@clerk/astro": "^3.4.6",
    "@heroicons/react": "^2.2.0",
    "@polar-sh/sdk": "^0.48.1",
    "@preline/accordion": "^4.2.0",
    "@preline/collapse": "^4.2.0",
    "@preline/dropdown": "^4.2.0",
    "@preline/overlay": "^4.2.0",
    "@preline/tabs": "^4.2.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@types/cors": "^2.8.19",
    "@vercel/nft": "^1.10.2",
    "astro-compress": "^2.3.9",
    "astro-compressor": "^1.2.0",
    "astro-vtbot": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "firebase-admin": "^14.0.0",
    "globby": "^16.1.0",
    "html-minifier-terser": "^7.2.0",
    "lenis": "^1.3.17",
    "lucide-react": "^1.21.0",
    "preline": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.14.0",
    "rimraf": "^6.1.2",
    "sharp": "^0.35.2",
    "sharp-ico": "^0.1.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/node": "10.1.4",
    "@astrojs/react": "^5.0.7",
    "@astrojs/vue": "^6.0.1",
    "@phosphor-icons/web": "^2.1.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "astro": "6.4.8",
    "astro-icon": "^1.1.5",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.2.3",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "nanoid": "^5.1.15",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "remark-directive": "^4.0.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "6.3.0",
      "svix": "1.92.2",
      "yaml": "2.8.4"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "protobufjs",
      "msw"
    ]
  }
}
