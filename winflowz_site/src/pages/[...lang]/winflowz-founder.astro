				<h2 class="mt-2 text-3xl font-bold text-neutral-900 dark:text-white">{copy.productHeading}</h2>
				<p class="mt-4 max-w-3xl text-neutral-600 dark:text-neutral-300">{copy.productSubheading}</p>
			</div>
			<div class="grid gap-6 rounded-2xl border border-neutral-200 bg-white p-8 dark:border-neutral-700 dark:bg-neutral-900">
				<h3 class="text-xl font-semibold text-neutral-900 dark:text-white">{copy.workflowHeading}</h3>
				<p class="text-sm text-neutral-600 dark:text-neutral-300">{copy.workflowText}</p>
				<div class="grid gap-4 md:grid-cols-3">
					{copy.workflowSteps.map((item) => (
						<div class="rounded-xl border border-neutral-200 bg-neutral-50 p-5 dark:border-neutral-700 dark:bg-neutral-800">
							<p class="mb-2 text-xs font-bold uppercase tracking-widest text-magenta">Step {item.step}</p>
							<h4 class="mb-2 text-lg font-semibold text-neutral-900 dark:text-white">{item.title}</h4>
							<p class="text-sm text-neutral-600 dark:text-neutral-300">{item.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-gradient-to-r from-violet-50 to-cyan-50 p-8 dark:border-neutral-700 dark:from-neutral-900 dark:to-neutral-900">
			<div class="mb-6">
				<h2 class="text-3xl font-bold text-neutral-900 dark:text-white">{copy.activationHeading}</h2>
				<p class="mt-4 max-w-3xl text-neutral-700 dark:text-neutral-300">{copy.activationText}</p>
			</div>
			<div class="grid gap-4 md:grid-cols-2">
				{copy.activationBullets.map((item) => (
					<div class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-700 dark:bg-neutral-800">
						<p class="text-sm text-neutral-700 dark:text-neutral-200">{item}</p>
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl">
			<div class="mb-6">
				<p class="text-sm font-semibold uppercase tracking-widest text-magenta">
					{lang === 'fr' ? 'Architecture commerciale' : 'Commercial structure'}
				</p>
				<h2 class="mt-2 text-3xl font-bold text-neutral-900 dark:text-white">{copy.tiersHeading}</h2>
				<p class="mt-4 max-w-3xl text-neutral-600 dark:text-neutral-300">{copy.tiersText}</p>
			</div>
			<div class="grid gap-6 md:grid-cols-3">
				{copy.tiers.map((tier) => (
					<div class="relative overflow-hidden rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-900">
						<p class="mb-2 inline-flex rounded-full border border-neutral-200 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-neutral-700 dark:border-neutral-600 dark:text-neutral-300">
							{tier.label}
						</p>
						<h3 class="mb-1 text-xl font-semibold text-neutral-900 dark:text-white">{tier.title}</h3>
						<p class="mb-4 text-sm text-neutral-500 dark:text-neutral-400">{tier.focus}</p>
						<p class="mb-4 text-sm text-neutral-700 dark:text-neutral-200">{tier.included}</p>
						<div class="mb-4 text-xs text-neutral-500 dark:text-neutral-400">Activation: {tier.activation}</div>
						<div class="text-sm font-semibold text-neutral-900 dark:text-white">{tier.state}</div>
						<a
							href={checkoutUrl(tier.offerId)}
							class="mt-5 inline-flex w-full items-center justify-center rounded-xl bg-neutral-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-neutral-200"
						>
							{lang === 'fr' ? 'Choisir ce niveau' : 'Choose this tier'}
						</a>
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-white px-6 py-10 dark:border-neutral-700 dark:bg-neutral-900">
			<h2 class="mb-4 text-3xl font-bold text-neutral-900 dark:text-white">{copy.trustHeading}</h2>
			<p class="mb-6 max-w-3xl text-neutral-600 dark:text-neutral-300">{copy.trustText}</p>
			<div class="grid gap-3 md:grid-cols-2">
				{copy.trustPoints.map((point) => (
					<div class="rounded-lg bg-neutral-50 p-4 text-sm text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200">
						{point}
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-900">
			<h2 class="mb-2 text-3xl font-bold text-neutral-900 dark:text-white">{copy.faqHeading}</h2>
			<p class="mb-6 text-neutral-600 dark:text-neutral-300">{copy.faqText}</p>
			<div class="space-y-3">
				{copy.faqItems.map((item) => (
					<div class="rounded-xl border border-neutral-200 bg-neutral-50 p-5 dark:border-neutral-700 dark:bg-neutral-800">
						<p class="mb-2 text-sm font-semibold text-neutral-900 dark:text-white">{item.question}</p>
						<p class="text-sm text-neutral-600 dark:text-neutral-300">{item.answer}</p>
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-magenta/40 bg-gradient-to-r from-magenta/90 to-purple-700 p-10 text-white">
			<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
				<div class="max-w-2xl">
					<h2 class="text-3xl font-bold">{copy.finalHeading}</h2>
					<p class="mt-4 text-white/90">{copy.finalText}</p>
				</div>
				<a
					href={checkoutUrl(defaultOfferId)}
					class="inline-flex items-center rounded-xl bg-white px-6 py-3 font-semibold text-neutral-900 transition-colors hover:bg-neutral-100"
				>
					{copy.finalAction}
				</a>
			</div>
		</section>
	</div>
</MainLayout>
