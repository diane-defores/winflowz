										<p class="text-xs text-blue-700 dark:text-blue-200">Capture &amp; prioritize</p>
									</div>
									<div class="rounded-lg bg-emerald-50 p-3 text-sm dark:bg-emerald-950/40">
										<p class="mb-1 text-xs font-semibold uppercase tracking-wider text-emerald-700 dark:text-emerald-300">Execution</p>
										<p class="text-xs text-emerald-700 dark:text-emerald-200">Plan &amp; ship</p>
									</div>
								</div>
							</div>
							<div class="mt-4 rounded-lg bg-neutral-100 p-3 text-xs text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400">
