						<div class="mt-3 h-2 rounded-full bg-neutral-300 dark:bg-neutral-700" />
						<div class="mt-2 h-2 w-20 rounded-full bg-neutral-300 dark:bg-neutral-700" />
					</div>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-white px-6 py-10 dark:border-neutral-700 dark:bg-neutral-900">
			<div class="mb-4 flex items-start justify-between gap-3">
				<h2 class="text-2xl font-semibold text-neutral-900 dark:text-white">{copy.availabilityTitle}</h2>
				<span class="rounded-full border border-neutral-300 px-3 py-1 text-xs font-medium text-neutral-600 dark:border-neutral-600 dark:text-neutral-400">
					{lang === 'fr' ? 'Disponibilite' : 'Availability'}
				</span>
			</div>
			<p class="mb-4 max-w-3xl text-neutral-600 dark:text-neutral-300">{copy.availabilityText}</p>
			<ul class="grid gap-3 md:grid-cols-2">
				{copy.availabilityBullets.map((item) => (
					<li class="rounded-lg border border-neutral-100 bg-neutral-50 p-4 text-sm text-neutral-600 dark:border-neutral-800 dark:bg-neutral-800 dark:text-neutral-300">
						{item}
					</li>
				))}
			</ul>
		</section>

		<section id="architecture" class="mx-auto max-w-6xl">
			<div class="mb-6">
				<p class="text-sm font-semibold uppercase tracking-widest text-magenta">
					{lang === 'fr' ? 'Conception produit' : 'Product architecture'}
