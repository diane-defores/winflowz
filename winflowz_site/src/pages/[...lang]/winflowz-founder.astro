const { lang = 'en' as Language } = Astro.props
const copy = copyByLang[lang]
const pagePath = lang === 'fr' ? '/fr/winflowz-founder' : '/winflowz-founder'
const defaultOfferId = 'winflowz_app/pro_founder'

function checkoutUrl(offerId: string) {
	const successUrl = `/purchase/success?offerId=${encodeURIComponent(offerId)}`
	const cancelUrl = `/purchase/cancel?offerId=${encodeURIComponent(offerId)}`
	return `/api/commerce/checkout?offerId=${encodeURIComponent(offerId)}&provider=lemonsqueezy&source=direct&sourceRef=${encodeURIComponent(pagePath)}&successUrl=${encodeURIComponent(successUrl)}&cancelUrl=${encodeURIComponent(cancelUrl)}`
}
---

<MainLayout
	title={copy.metaTitle}
	meta={{
		title: copy.metaTitle,
		description: copy.metaDescription,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, '/winflowz-founder'),
		url: getLocalizedSiteUrl(lang, '/winflowz-founder'),
		name: copy.metaTitle,
		description: copy.metaDescription,
		inLanguage: lang,
	}}
>
	<div class="space-y-16 pb-16">
		<section class="relative overflow-hidden rounded-2xl border border-neutral-200/80 bg-gradient-to-br from-white to-neutral-50 p-8 md:p-12 dark:border-neutral-700 dark:from-neutral-900 dark:to-neutral-950">
			<div class="absolute inset-x-0 top-0 h-2 bg-gradient-rainbow-horizontal opacity-80" />
			<div class="absolute inset-0 bg-gradient-to-br from-magenta/10 via-transparent to-cyan/10" />
			<div class="relative mx-auto grid max-w-6xl gap-12 lg:grid-cols-2 lg:items-center">
				<div class="max-w-2xl">
					<p class="mb-4 inline-flex rounded-full border border-magenta/40 bg-magenta/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-magenta">
						{copy.badge}
					</p>
					<h1 class="mb-6 text-4xl font-bold text-neutral-900 dark:text-white sm:text-5xl">
						{copy.heroTitle}
					</h1>
					<p class="mb-8 text-lg leading-relaxed text-neutral-600 dark:text-neutral-300">
						{copy.heroSubtitle}
					</p>
					<div class="flex flex-wrap gap-4">
						<a
							href={checkoutUrl(defaultOfferId)}
							class="inline-flex items-center rounded-xl bg-magenta px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-magenta/90"
						>
							{copy.primaryAction}
						</a>
						<a
							href="#architecture"
							class="inline-flex items-center rounded-xl border border-neutral-300 bg-white/80 px-6 py-3 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-100 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:hover:bg-neutral-700"
						>
							{copy.secondaryAction}
						</a>
					</div>
				</div>
				<div class="relative">
					<div class="mx-auto w-full max-w-sm rounded-3xl border border-neutral-200 bg-white p-4 shadow-2xl shadow-black/10 ring-1 ring-black/5 dark:border-neutral-700 dark:bg-neutral-900 dark:ring-white/5">
						<div class="rounded-2xl bg-gradient-to-b from-neutral-100 to-white p-3 dark:from-neutral-800 dark:to-neutral-900">
							<div class="h-5 w-36 rounded-full bg-neutral-200 dark:bg-neutral-700" />
							<div class="mt-3 h-8 rounded-xl bg-magenta/10 p-2">
								<div class="h-3 w-24 rounded-full bg-magenta/30 dark:bg-magenta/40" />
							</div>
							<div class="mt-4 space-y-3">
								<div class="space-y-2 rounded-xl border border-neutral-200 bg-white p-3 dark:border-neutral-700 dark:bg-neutral-800">
									<div class="h-2 w-3/4 rounded-full bg-neutral-300 dark:bg-neutral-600" />
									<div class="h-2 w-1/2 rounded-full bg-neutral-300 dark:bg-neutral-600" />
								</div>
								<div class="rounded-xl border border-neutral-200 bg-white p-3 dark:border-neutral-700 dark:bg-neutral-800">
									<div class="mb-2 text-xs font-semibold text-neutral-500 dark:text-neutral-400">
										{copy.productSubheading}
									</div>
									<div class="h-2 w-full rounded-full bg-neutral-300 dark:bg-neutral-600" />
									<div class="mt-2 h-2 w-5/6 rounded-full bg-neutral-300 dark:bg-neutral-600" />
								</div>
								<div class="grid grid-cols-2 gap-2">
									<div class="rounded-lg bg-blue-50 p-3 text-sm dark:bg-blue-950/40">
