---
import MainLayout from '@/layouts/MainLayout.astro'
import type { Language } from '@/types'
import { getLocalizedSiteUrl } from '@/constants'

export const prerender = true

export async function getStaticPaths() {
	return [
		{
			params: { lang: undefined },
			props: { lang: 'en' as Language },
		},
		{
			params: { lang: 'fr' },
			props: { lang: 'fr' as Language },
		},
	]
}

interface Tier {
	title: string
	label: string
	focus: string
	included: string
	activation: string
	state: string
	offerId: string
}

interface WorkflowStep {
	step: string
	title: string
	description: string
}

interface FaqItem {
	question: string
	answer: string
}

interface CopyBlock {
	metaTitle: string
	metaDescription: string
	heroTitle: string
	heroSubtitle: string
	badge: string
	primaryAction: string
	secondaryAction: string
	availabilityTitle: string
	availabilityText: string
	availabilityBullets: string[]
	productHeading: string
	productSubheading: string
	workflowHeading: string
	workflowText: string
	workflowSteps: WorkflowStep[]
	activationHeading: string
	activationText: string
	activationBullets: string[]
	tiersHeading: string
	tiersText: string
	tiers: Tier[]
	trustHeading: string
	trustText: string
	trustPoints: string[]
	faqHeading: string
	faqText: string
	faqItems: FaqItem[]
	finalHeading: string
	finalText: string
	finalAction: string
	finalActionUrl: string
}

